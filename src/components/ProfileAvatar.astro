---
import { Image } from "astro:assets";
import { githubAvatarUrl, githubProfileUrl, githubUsername } from "../config/site";

interface Props {
  size?: number;
  class?: string;
}

const { size = 96, class: className = "" } = Astro.props;
const avatarUrl = githubAvatarUrl(size * 2);
---

<a
  href={githubProfileUrl()}
  class:list={["profile-avatar-link", className]}
  style={`--avatar-size: ${size}px`}
  aria-label={`@${githubUsername} on GitHub`}
  rel="me"
>
  <Image
    src={avatarUrl}
    alt=""
    class="profile-avatar"
    width={size}
    height={size}
    loading="eager"
    decoding="async"
  />
</a>
